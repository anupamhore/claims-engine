# ============================================
# DEPLOYMENT MODE (Docker or Local)
# ============================================
# Set to 'docker' for Docker Compose (Phase 2+)
# Set to 'local' for Homebrew/local installation
DEPLOYMENT_MODE=docker

# API Configuration
APP_NAME=Claims-Triage-Engine
APP_ENV=development
LOG_LEVEL=DEBUG

# Database: PostgreSQL
# For Docker: Use service name 'postgres' instead of localhost
# For local/Homebrew: Use 'localhost'
DB_HOST=postgres
DB_PORT=5433
DB_USER=claims_user
DB_PASSWORD=your_secure_password
DB_NAME=claims_db

# Database Connection Pool Configuration
# WHY: Connection pooling reuses database connections for performance
#
# DB_POOL_SIZE: Number of connections kept ready in the pool (always open)
#   - Development: 20 (safe margin for local testing)
#   - Production: 20-50 (depends on concurrent requests expected)
#   - Insurance app typical: 20-30 (not super high traffic like Twitter)
#   - Each connection uses ~10MB memory
#   - 20 connections = ~200MB memory usage
#   - Formula: 1.5-2x your expected concurrent database requests
#
# DB_MAX_OVERFLOW: Extra connections created on-demand during traffic spikes
#   - Development: 40 (safety for testing spikes)
#   - Production: 40-100 (depends on how much spike you expect)
#   - These are temporary and destroyed after use (slower than pool)
#   - Insurance app typical: 40-60
#   - Formula: 2-3x your DB_POOL_SIZE
#
# TOTAL CONNECTIONS = DB_POOL_SIZE + DB_MAX_OVERFLOW
#   - Development: 20 + 40 = 60 max
#   - Production: Adjust based on expected traffic
#
# For this insurance claims app:
#   - Production values shown will stay the same
#   - Reason: Modest traffic load (not high-frequency trading)
#   - Can scale horizontally with multiple FastAPI instances if needed
#
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Cache: Redis
# For Docker: Use service name 'redis' instead of localhost
# For local/Homebrew: Use 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Redis Authentication & Security
# REDIS_PASSWORD: Used to authenticate to Redis
#
# Development Setup:
#   - REDIS_PASSWORD=optional_password  (or leave empty for local testing)
#   - Docker container: password protection optional
#   - Reason: Local development, not exposed to internet
#
# Production Setup (Phase 9 - AWS Deployment):
#   - REDIS_PASSWORD=<strong_random_password>  (REQUIRED)
#   - AWS ElastiCache: Always enable encryption
#   - Use AWS Secrets Manager to store password
#   - Example value: 44-character random string from: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   - Never commit to Git - use environment variables in Kubernetes secrets
#
# For This Project (Development):
#   - Leave as optional for Docker Compose
#   - Will upgrade to secure production password in Phase 9 (AWS deployment)
#
REDIS_PASSWORD=optional_password
REDIS_TTL=86400  # 24 hours cache expiration

# Message Queue: Kafka
# For Docker: Use service name 'kafka' instead of localhost (will be added in Phase 6)
# For local/Homebrew: Use 'localhost'
KAFKA_BROKERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_CONSUMER_GROUP=claims-processor

# LLM: Groq (Primary)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=mixtral-8x7b-32768
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=500

# LLM: OpenAI (Fallback)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=500

# ML Models
MODEL_CACHE_DIR=./models
BERT_MODEL_NAME=distilbert-base-uncased
XGBOOST_MODEL_PATH=./models/xgboost_fraud_model.pkl
MIN_CONFIDENCE_THRESHOLD=0.7

# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
S3_BUCKET_NAME=claims-engine-bucket
ECR_REGISTRY=your_account.dkr.ecr.ap-southeast-1.amazonaws.com

# ============================================
# Security & Authentication (CRITICAL for Production)
# ============================================
#
# SECRET_KEY: Used to sign JWT tokens (prevents token forgery)
# 
# Development Setup:
#   - SECRET_KEY=your_jwt_secret_key  (placeholder, not used locally)
#   - FastAPI will warn if weak key in development
#   
# Production Setup (Phase 9 - AWS Deployment):
#   - SECRET_KEY=<256-bit random key>
#   - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   - Store in: AWS Secrets Manager (Phase 9)
#   - In Kubernetes: Mounted as secret, never in .env file
#   - CRITICAL: If leaked, attackers can forge valid tokens
#   - Rotate every 90 days in production
#   - DO NOT commit to Git (add .env to .gitignore - already done)
#
# Example production generation:
#   $ python -c "import secrets; print(secrets.token_urlsafe(32))"
#   # Returns: ABC123XYZ...etc (43+ characters)
#
SECRET_KEY=your_jwt_secret_key_change_in_production

# API_KEY_HEADER_NAME: HTTP header name for API authentication
#
# Development Setup:
#   - API_KEY_HEADER_NAME=X-API-Key  (standard header name)
#   - Use this header when calling API: curl -H "X-API-Key: test-key" http://localhost:8000/api/v1/health
#
# Production Setup (Phase 9 - AWS Deployment):
#   - Same header name (X-API-Key is industry standard)
#   - API keys stored in: AWS Secrets Manager
#   - Multiple keys for different services (ML worker, Streamlit, external partners)
#   - Keys rotated monthly
#
API_KEY_HEADER_NAME=X-API-Key

# JWT Configuration
JWT_ALGORITHM=HS256  # HS256 is industry standard for web APIs
JWT_EXPIRATION_HOURS=24  # Tokens expire after 24 hours (requires re-login)

# ============================================
# Monitoring & Logging (Optional but Recommended)
# ============================================
#
# SENTRY_DSN: Error tracking and monitoring
#
# Development Setup:
#   - SENTRY_DSN=optional_sentry_url  (disabled for development)
#   - Reason: Don't want dev errors cluttering production error tracking
#
# Production Setup (Phase 9 - AWS Deployment):
#   - SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/zzzzz
#   - Sign up at: https://sentry.io (has free tier)
#   - Captures all production errors automatically
#   - Alerts on critical errors in real-time
#   - Provides error context (user, request, stack trace)
#   - CRITICAL for production monitoring
#   - Cost: Free tier = 5,000 errors/month (usually enough)
#
# Why Sentry for insurance app:
#   - Catches fraud detection errors automatically
#   - Tracks LLM hallucinations/failures
#   - Monitors database connection issues
#   - Provides alerting dashboard
#
SENTRY_DSN=optional_sentry_url_add_in_production_phase_9

LOG_FORMAT=json  # json format for structured logging in production
